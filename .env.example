# Copy to .env and replace values. Never commit real secrets.

# Runtime
APP_ENV=development
APP_NAME=Flight Hunter
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://api:8000
DEFAULT_LOCALE=ru
DEFAULT_TIMEZONE=Europe/Warsaw
DEFAULT_CURRENCY=PLN
LOG_LEVEL=INFO

# Security
APP_SECRET_KEY=replace-with-strong-random-secret
FIELD_ENCRYPTION_KEY=replace-with-32-byte-base64-key
SESSION_COOKIE_SECURE=false
INVITATION_ONLY=true
OWNER_BOOTSTRAP_EMAIL=owner@example.com

# PostgreSQL/PostGIS
POSTGRES_DB=flight_hunter
POSTGRES_USER=flight_hunter
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql+asyncpg://flight_hunter:replace-me@postgres:5432/flight_hunter

# Redis / workers
REDIS_URL=redis://redis:6379/0
WORKER_CONCURRENCY=4
SCHEDULER_ENABLED=true

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_TRANSPORT=webhook
TELEGRAM_FAKE_SINK=true

# LLM is optional; core product must work without it
LLM_ENABLED=false
LLM_PROVIDER=openai_compatible
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MAX_COST_PER_REQUEST=

# Agent mode / presets
AGENT_MODE_ENABLED=true
AGENT_PROVIDER=deterministic_presets
AGENT_MCP_ENABLED=false
AGENT_MCP_SERVER=
AGENT_CODEX_CLI_ENABLED=false
AGENT_CODEX_CLI_TIMEOUT_SECONDS=8
AGENT_CODEX_CLI_SERVICE_TIER=fast
AGENT_OPENAI_ENABLED=false
AGENT_OPENAI_MODEL=gpt-5.5
AGENT_OPENAI_TIMEOUT_SECONDS=8
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Live refresh safety
LIVE_REFRESH_MIN_GAP_SECONDS=600

# Risky price observer. Keep off until each source is checked and explicitly approved.
SCRAPING_OBSERVER_ENABLED=false
SCRAPING_MIN_GAP_SECONDS=600

# Aviasales Data API / Travelpayouts
AVIASALES_DATA_ENABLED=false
TRAVELPAYOUTS_API_TOKEN=
TRAVELPAYOUTS_MARKER=
AVIASALES_DATA_DEFAULT_MARKET=pl
AVIASALES_DATA_INTERNAL_RPM=30

# Aviasales Search API — keep disabled until approved access and 50k+ confirmed MAU
AVIASALES_SEARCH_ENABLED=false
AVIASALES_SEARCH_ACCESS_APPROVED=false
AVIASALES_SEARCH_CONFIRMED_MAU_50000=false
AVIASALES_SEARCH_TOKEN=
AVIASALES_SEARCH_MARKER=
AVIASALES_SEARCH_REAL_HOST=

# Skyscanner — keep disabled until partnership approval
SKYSCANNER_INDICATIVE_ENABLED=false
SKYSCANNER_LIVE_ENABLED=false
SKYSCANNER_ACCESS_APPROVED=false
SKYSCANNER_API_KEY=

# Duffel
DUFFEL_ENABLED=false
DUFFEL_MODE=test
DUFFEL_ACCESS_TOKEN=
DUFFEL_BACKGROUND_POLLING_ALLOWED=false

# Amadeus legacy/enterprise only
AMADEUS_ENABLED=false
AMADEUS_ACCESS_MODE=disabled
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BACKGROUND_POLLING_ALLOWED=false

# Feature flags
FEATURE_SPLIT_TICKETS=true
FEATURE_SELF_TRANSFER=true
FEATURE_HIDDEN_CITY_RESEARCH=false
FEATURE_DEAL_FEEDS=true
FEATURE_HOT_DEAL_SCANNER=true
FEATURE_PWA=true

# Airport/reference data
OURAIRPORTS_IMPORT_ENABLED=true
OURAIRPORTS_IMPORT_SCHEDULE=0 3 * * *
NEARBY_AIRPORT_DEFAULT_RADIUS_KM=150
NEARBY_AIRPORT_MAX_RADIUS_KM=300

# FX / cost model
FX_PROVIDER=ecb_or_configured
DEFAULT_CARD_FX_FEE_PERCENT=0
GROUND_TRANSFER_ESTIMATES_ENABLED=true

# Storage / retention
RAW_PROVIDER_PAYLOAD_RETENTION_DAYS=0
PRICE_HISTORY_RETENTION_DAYS=0
AUDIT_LOG_RETENTION_DAYS=365
OBJECT_STORAGE_ENABLED=false
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true
SENTRY_DSN=

# Backups
BACKUP_ENABLED=true
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=14
BACKUP_ENCRYPTION_KEY=
